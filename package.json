{
  "name": "artinus-fe",
  "private": true,
  "version": "0.1.0",
  "description": "ARTINUS 프론트엔드 과제 — 상품(products) · 회원가입(signup) 모노레포",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:products": "pnpm --filter @artinus/products dev",
    "dev:signup": "pnpm --filter @artinus/signup dev",
    "build": "pnpm -r --filter \"./apps/*\" build",
    "build:products": "pnpm --filter @artinus/products build",
    "build:signup": "pnpm --filter @artinus/signup build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@artinus/config": "workspace:*",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
